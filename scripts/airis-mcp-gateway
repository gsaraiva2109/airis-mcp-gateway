#!/usr/bin/env bash
set -euo pipefail

# AIRIS MCP Gateway - Infinite Context Bridge
# STANDALONE TOOL - This is an optional extension for airis-mcp-gateway.
# Provides integration with NCP (discovery), RTK (tokens), and ICM (memory).

API_URL="${AIRIS_API_URL:-http://localhost:9400}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info()  { echo -e "${GREEN}[INFO]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

cmd_help() {
    cat <<EOF
AIRIS Infinite Context Bridge (Optional Tool)

This script extends airis-mcp-gateway with "Infinite Context Bridge" layers:
- Layer 1 (active):   Airis Dynamic MCP    — ~98% tool schema token reduction
- Layer 2 (optional): RTK                  — 60-90% bash output token reduction
- Layer 3 (optional): ICM                  — persistent cross-session memory

Usage: airis-mcp-gateway <command> [options]

Commands:
  exec <tool> [--params <json>]  Execute any gateway tool with auto-enablement
  bridge rtk                     Install RTK hooks for Claude Code
  bridge icm                     Register ICM memory MCP with Claude Code

Environment variables:
  AIRIS_API_URL       API URL (default: http://localhost:9400)

Examples:
  airis-mcp-gateway exec airis-find --params '{"query": "memory"}'
  airis-mcp-gateway exec filesystem:list_directory --params '{"path": "/workspace/host"}'
  airis-mcp-gateway bridge rtk
  airis-mcp-gateway bridge icm
EOF
}

case "${1:-help}" in
    exec)
        shift
        if [ $# -lt 1 ]; then
            log_error "Tool name is required."
            exit 1
        fi
        TOOL_NAME="$1"
        shift
        PARAMS="{}"
        if [ "${1:-}" == "--params" ]; then
            shift
            if [ $# -lt 1 ]; then log_error "JSON arguments required after --params."; exit 1; fi
            PARAMS="$1"
        fi
        
        # Check API health
        if ! curl -fsS --connect-timeout 2 "$API_URL/health" > /dev/null; then
            log_error "Gateway API not reachable at $API_URL. Is it running?"
            exit 1
        fi

        if ! command -v jq >/dev/null 2>&1; then
            log_error "jq is not installed. Please install jq to use this tool."
            exit 1
        fi

        TMP_FILE=$(mktemp)
        trap 'rm -f "$TMP_FILE"' EXIT

        # Validate that PARAMS is valid JSON
        if ! echo "$PARAMS" | jq empty >/dev/null 2>&1; then
            log_error "Invalid JSON passed to --params: $PARAMS"
            exit 1
        fi

        # Validate tool name (alphanumeric, hyphens, underscores, colons only)
        if ! [[ "$TOOL_NAME" =~ ^[a-zA-Z0-9_:/-]+$ ]]; then
            log_error "Invalid tool name: $TOOL_NAME"
            exit 1
        fi

        # Wrap in airis-exec unless it's already a meta-tool; build payload safely with jq
        if [[ "$TOOL_NAME" == airis-* ]] || [[ "$TOOL_NAME" == airis_* ]] || [[ "$TOOL_NAME" == "expandSchema" ]]; then
            PAYLOAD=$(jq -n --arg name "$TOOL_NAME" --argjson args "$PARAMS" \
                '{"jsonrpc":"2.0","id":1,"method":"tools/call","params":{"name":$name,"arguments":$args}}')
        else
            PAYLOAD=$(jq -n --arg tool "$TOOL_NAME" --argjson args "$PARAMS" \
                '{"jsonrpc":"2.0","id":1,"method":"tools/call","params":{"name":"airis-exec","arguments":{"tool":$tool,"arguments":$args}}}')
        fi

        echo "$PAYLOAD" > "$TMP_FILE"
        curl -s -X POST "$API_URL/mcp/" -H "Content-Type: application/json" -d @"$TMP_FILE" | jq -C '.result'
        ;;

    bridge)
        shift
        case "${1:-help}" in
            icm)
                log_info "Registering ICM with Claude Code (user scope)..."
                if ! command -v icm >/dev/null 2>&1; then
                    log_error "ICM not found. Install from: https://github.com/rtk-ai/icm"
                    exit 1
                fi
                if ! command -v claude >/dev/null 2>&1; then
                    log_error "Claude Code CLI not found. Install from: https://claude.ai/code"
                    exit 1
                fi
                if claude mcp get icm >/dev/null 2>&1; then
                    log_info "ICM is already registered with Claude Code."
                else
                    claude mcp add --scope user icm -- icm serve
                    log_info "ICM registered. Restart Claude Code to activate."
                fi
                ;;
            rtk)
                log_info "Installing RTK hooks for Claude Code..."
                if ! command -v rtk >/dev/null 2>&1; then
                    log_error "RTK not found. Install with:"
                    log_error "  curl -fsSL https://raw.githubusercontent.com/rtk-ai/rtk/refs/heads/master/install.sh | sh"
                    exit 1
                fi
                rtk init -g
                log_info "RTK hooks active. Bash commands will be optimized automatically."
                ;;
            *)
                log_error "Usage: airis-mcp-gateway bridge <rtk|icm>"
                exit 1
                ;;
        esac
        ;;

    help|--help|-h) cmd_help ;;
    *)
        log_error "Unknown command: $1"
        cmd_help
        exit 1
        ;;
esac
