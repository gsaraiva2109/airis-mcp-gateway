#!/usr/bin/env bash
set -euo pipefail

# AIRIS MCP Gateway - Infinite Context Bridge
# STANDALONE TOOL - This is an optional extension for airis-mcp-gateway.
# Provides integration with NCP (discovery), RTK (tokens), and ICM (memory).

API_URL="${AIRIS_API_URL:-http://localhost:9400}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info()  { echo -e "${GREEN}[INFO]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

cmd_help() {
    cat <<EOF
AIRIS Infinite Context Bridge (Optional Tool)

This script extends airis-mcp-gateway with "Infinite Context" features:
- Tool Discovery (meta-tools)
- Token Optimization (RTK)
- Memory Ranking (ICM)

Usage: airis-mcp-gateway <command> [options]

Commands:
  exec <tool> [--params <json>]  Execute any tool with auto-enablement
  bridge ncp                     (Optional) Link all MCP servers to NCP
  bridge icm                     (Optional) Link ICM database to RTK context

Environment variables:
  AIRIS_API_URL       API URL (default: http://localhost:9400)

Examples:
  airis-mcp-gateway exec airis-find --params '{"query": "memory"}'
  airis-mcp-gateway exec filesystem:list_directory --params '{"path": "/workspace/host"}'
EOF
}

case "${1:-help}" in
    exec)
        shift
        if [ $# -lt 1 ]; then
            log_error "Tool name is required."
            exit 1
        fi
        TOOL_NAME="$1"
        shift
        PARAMS="{}"
        if [ "${1:-}" == "--params" ]; then
            shift
            if [ $# -lt 1 ]; then log_error "JSON arguments required after --params."; exit 1; fi
            PARAMS="$1"
        fi
        
        # Check API health
        if ! curl -s --connect-timeout 2 "$API_URL/health" > /dev/null; then
            log_error "Gateway API not reachable at $API_URL. Is it running?"
            exit 1
        fi
        
        TMP_FILE=$(mktemp)
        trap "rm -f $TMP_FILE" EXIT
        
        # Wrap in airis-exec unless it's already a meta-tool
        if [[ "$TOOL_NAME" == airis-* ]] || [[ "$TOOL_NAME" == airis_* ]] || [[ "$TOOL_NAME" == "expandSchema" ]]; then
            PAYLOAD="{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"tools/call\",\"params\":{\"name\":\"$TOOL_NAME\",\"arguments\":$PARAMS}}"
        else
            PAYLOAD="{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"tools/call\",\"params\":{\"name\":\"airis-exec\",\"arguments\":{\"tool\":\"$TOOL_NAME\",\"arguments\":$PARAMS}}}"
        fi
        
        echo "$PAYLOAD" > "$TMP_FILE"
        curl -s -X POST "$API_URL/mcp/" -H "Content-Type: application/json" -d @"$TMP_FILE" | jq -C '.result'
        ;;

    bridge)
        shift
        case "${1:-help}" in
            ncp)
                log_info "Linking servers to NCP..."
                NCP_BIN="$HOME/.ncp/node_modules/.bin/ncp"
                if [ ! -f "$NCP_BIN" ]; then log_error "NCP not found at $NCP_BIN"; exit 1; fi
                for tool in filesystem memory github tavily supabase stripe context7 sequential-thinking serena; do
                    "$NCP_BIN" add "$tool" "airis-mcp-gateway exec $tool"
                done
                log_info "NCP bridge complete."
                ;;
            icm)
                log_info "Linking ICM database to RTK context..."
                mkdir -p ~/.rtk
                ln -sf "$HOME/.local/share/icm/memories.db" "$HOME/.rtk/icm.db"
                log_info "ICM memory bridge active."
                ;;
            *)
                log_error "Usage: airis-mcp-gateway bridge <ncp|icm>"
                exit 1
                ;;
        esac
        ;;

    help|--help|-h) cmd_help ;;
    *)
        log_error "Unknown command: $1"
        cmd_help
        exit 1
        ;;
esac
