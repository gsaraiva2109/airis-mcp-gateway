# ==========================================
# AIRIS MCP Gateway Configuration
# ==========================================

# Serena mode: serena-local (stdio, 2 containers) or serena-remote (SSE, 3 containers)
# dev: serena-local (faster, no container overhead)
# prod: serena-remote (isolated, volume-mounted container)
SERENA_MODE=serena-local

# Database (optional - defaults work for local dev)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mcp_gateway

# Config directory (XDG compliant)
# Default: ~/.config/airis-mcp-gateway
# AIRIS_CONFIG_DIR=~/.config/airis-mcp-gateway

# Workspace directory (mounted to /workspace/host in containers)
# Default: ~/github
# HOST_WORKSPACE_DIR=~/github

# Encryption key for secret storage (generate for production)
# python -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
ENCRYPTION_MASTER_KEY=your-32-byte-base64-encoded-key-here

# API Authentication (optional - disabled by default)
# If set, all requests require: Authorization: Bearer <key>
# Generate: openssl rand -hex 32
# AIRIS_API_KEY=your-api-key-here

# External API Keys (optional - for specific MCP servers)

# Tavily - Web search
# Get your free API key at https://tavily.com
# TAVILY_API_KEY=tvly-xxx

# Supabase - Database management
# Get access token at https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_xxx

# Stripe - Payment processing
# Get secret key at https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_xxx

# Twilio - Voice/SMS
# Create API Key at https://console.twilio.com > Account > API Keys
# TWILIO_ACCOUNT_SID=ACxxx
# TWILIO_API_KEY=SKxxx
# TWILIO_API_SECRET=xxx

# Cloudflare - DNS, Workers, KV, R2
# Create token at https://dash.cloudflare.com/profile/api-tokens
# CLOUDFLARE_ACCOUNT_ID=xxx
# CLOUDFLARE_API_TOKEN=xxx

# GitHub - Repository management
# Create token at https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_xxx

# Magic (21st.dev) - UI component generation
# Get your API key at https://21st.dev
# MAGIC_API_KEY=xxx

# MorphLLM - Code editing
# Get your API key at https://morphllm.com
# MORPH_API_KEY=sk-xxx

# ==========================================
# Advanced Configuration
# ==========================================

# MCP Server Timeouts
# Tool call timeout in seconds (default: 90)
# TOOL_CALL_TIMEOUT=90

# Graceful shutdown timeout in seconds (default: 10)
# SHUTDOWN_TIMEOUT=10

# Buffer Limits
# Stdout buffer limit for MCP responses (default: 1MB)
# Increase for tools with large responses
# MCP_STDOUT_BUFFER_LIMIT=1048576

# Dynamic MCP Mode
# Set to false to expose all tools directly (default: true)
# DYNAMIC_MCP=true
# Meta-Tools Mode
# "core" (default): 3 tools (find/exec/schema) ~600 tokens
# "full": 7 tools (+ confidence/repo-index/suggest/route) ~1400 tokens
# META_TOOLS_MODE=core

# Tool Listing Mode
# "compact" (default): top 3 tools per server with +N count
# "full": all tool names listed
# TOOL_LISTING_MODE=compact

# Docker Gateway URL (internal)
# MCP_GATEWAY_URL=http://gateway:9390

# MCP Config Path (internal)
# MCP_CONFIG_PATH=/app/mcp-config.json
