{
  "$schema": "https://raw.githubusercontent.com/agiletec-inc/airis-mcp-gateway/main/config/mcp-config.schema.json",
  "mcpServers": {
    "mindbase": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/agiletec-inc/mindbase#subdirectory=mcp",
        "mindbase-mcp"
      ],
      "env": {
        "MINDBASE_URL": "${MINDBASE_URL:-http://localhost:18003}"
      },
      "enabled": true,
      "mode": "hot",
      "description": "Long-term memory with semantic search"
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {},
      "enabled": true,
      "mode": "cold",
      "description": "Official library documentation (15,000+ libraries)",
      "behavior": {
        "triggers": ["implementing with any library/framework", "unsure about API usage"],
        "instruction": "Lookup docs BEFORE writing code",
        "priority": "high"
      }
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "env": {},
      "enabled": true,
      "mode": "cold",
      "description": "Multi-step reasoning and complex analysis"
    },
    "serena": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "http://serena:8000/sse", "--allow-http"],
      "env": {},
      "enabled": true,
      "mode": "cold",
      "description": "Semantic code navigation and refactoring"
    },
    "tavily": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.tavily.com/mcp/?tavilyApiKey=${TAVILY_API_KEY}"],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      },
      "enabled": true,
      "mode": "cold",
      "description": "Web search for deep research",
      "behavior": {
        "triggers": ["need current/external information", "researching best practices"],
        "instruction": "Search web for up-to-date info",
        "priority": "medium"
      }
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "env": {},
      "enabled": true,
      "mode": "cold",
      "description": "HTTP requests"
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {},
      "enabled": true,
      "mode": "hot",
      "description": "Session memory"
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/workspace"],
      "env": {},
      "enabled": false,
      "mode": "cold",
      "description": "File read/write/search"
    },
    "git": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-git"],
      "env": {},
      "enabled": false,
      "mode": "cold",
      "description": "Git operations"
    },
    "time": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-time"],
      "env": {},
      "enabled": false,
      "mode": "cold",
      "description": "Current time"
    },
    "stripe": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.stripe.com/"],
      "env": {},
      "enabled": true,
      "mode": "cold",
      "description": "Stripe API: customers, products, prices, subscriptions (OAuth)"
    },
    "supabase": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.supabase.com/mcp"],
      "env": {},
      "enabled": true,
      "mode": "cold",
      "description": "Supabase: database, migrations, Edge Functions (OAuth)"
    }
  },
  "log": {
    "level": "info"
  }
}
